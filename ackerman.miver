Programa ackermanmi
 
	(define ( ackerman m int n int)	
		(define(res int 0)
			(if ((== m  0)) 
			 ( res = (+ n  1))  
		else ( 
			  (if ((== n  0))
				  (	res= (ackerman (- m  1) 1)	)
			  else (
				   res=(ackerman (- m  1) (ackerman m  (- n  1) )	)
				   					
					) 
				)		
		)	  
		  
		)
		) end res)	
		
 > (ackerman 3 4) 